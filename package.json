{
  "private": true,
  "license": "Apache-2.0",
  "name": "@kyma-project/busola",
  "version": "0.0.1-rc.8",
  "type": "module",
  "scripts": {
    "postinstall": "cd backend && npm install",
    "start": "concurrently -c cyan,green npm:busola npm:backend",
    "busola": "npm run copy-themes; BROWSER=none GENERATE_SOURCEMAP=false vite",
    "backend": "cd backend && npm run start",
    "eslint-check": "eslint --quiet src/ backend/",
    "eslint-fix": "eslint --fix src/ backend/",
    "lint-check": "prettier --config ./.prettierrc --ignore-path ./.prettierignore --check '**/*.{ts,tsx,js,jsx,json,html,css,yaml,md}'",
    "lint-fix": "prettier --config ./.prettierrc --ignore-path ./.prettierignore --write '**/*.{ts,tsx,js,jsx,json,html,css,yaml,md}'",
    "lint-staged": "lint-staged --concurrent=false",
    "test": "vitest",
    "component-test": "npx cypress open --config-file cypress.config.component.ts",
    "component-test-headless": "npx cypress run --headless --config-file cypress.config.component.ts --component --browser chrome",
    "build": "npm run copy-themes; INLINE_RUNTIME_CHUNK=false GENERATE_SOURCEMAP=false NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build:docker": "npm run copy-themes; INLINE_RUNTIME_CHUNK=false GENERATE_SOURCEMAP=false NODE_OPTIONS=--max-old-space-size=8192 IS_DOCKER=true vite build",
    "copy-themes": "cp node_modules/@sap-theming/theming-base-content/content/Base/baseLib/sap_horizon/css_variables.css public/themes/@sap-theming/default.css; for theme in hcb dark hcw ; do cp node_modules/@sap-theming/theming-base-content/content/Base/baseLib/sap_horizon_$theme/css_variables.css public/themes/@sap-theming/$theme.css ; done",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "unsafe-perm": true
  },
  "dependencies": {
    "@datasert/cronjs-parser": "^1.4.0",
    "@fundamental-styles/common-css": "^0.30.2",
    "@openapi-contrib/openapi-schema-to-json-schema": "^5.1.0",
    "@peculiar/x509": "^1.12.3",
    "@sap-theming/theming-base-content": "^11.1.28",
    "@sentry/react": "^9.9.0",
    "@stoplight/json-ref-resolver": "^3.1.6",
    "@tippyjs/react": "^4.2.6",
    "@types/jsonpath": "^0.2.4",
    "@types/pluralize": "^0.0.29",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@ui-schema/ui-schema": "^0.4.7",
    "@ui5/webcomponents": "^2.19.1",
    "@ui5/webcomponents-base": "^2.19.1",
    "@ui5/webcomponents-compat": "^2.19.1",
    "@ui5/webcomponents-fiori": "^2.19.1",
    "@ui5/webcomponents-icons": "^2.19.1",
    "@ui5/webcomponents-icons-tnt": "^2.19.1",
    "@ui5/webcomponents-react": "^2.19.0",
    "@ui5/webcomponents-react-base": "^2.19.0",
    "@ui5/webcomponents-react-charts": "^2.19.0",
    "@ui5/webcomponents-react-compat": "^2.19.0",
    "@viz-js/viz": "^3.11.0",
    "classnames": "^2.5.1",
    "compare-versions": "^6.1.1",
    "copy-to-clipboard": "^3.2.0",
    "core-js": "^3.41.0",
    "cronstrue": "^2.56.0",
    "didyoumean": "^1.2.2",
    "file-saver": "^2.0.2",
    "glob": "^13.0.0",
    "http-status-codes": "^2.3.0",
    "i18next": "^25.6.0",
    "i18next-http-backend": "^3.0.2",
    "immutable": "^5.1.1",
    "jotai": "^2.13.0",
    "jotai-effect": "^2.0.5",
    "js-tiktoken": "^1.0.20",
    "js-yaml": "^4.1.0",
    "jsonata": "^2.1.0",
    "jsonpath": "^1.2.0",
    "jsonschema": "^1.5.0",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.23",
    "marked": "^15.0.7",
    "marked-react": "^3.0.0",
    "monaco-editor": "^0.52.2",
    "monaco-yaml": "^5.4.0",
    "oidc-client-ts": "^3.2.0",
    "p-queue": "^8.1.0",
    "pako": "^2.0.4",
    "pluralize": "^8.0.0",
    "prop-types": "^15.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.1.5",
    "react-router": "^7.13.0",
    "react-syntax-highlighter": "^15.6.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "resize-observer-polyfill": "^1.5.1",
    "rfc6902": "^5.1.2",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@nabla/vite-plugin-eslint": "^2.0.6",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.1",
    "@types/didyoumean": "^1.2.0",
    "@types/file-saver": "^2.0.5",
    "@types/js-yaml": "^4.0.5",
    "@types/lodash": "^4.14.186",
    "@types/node": "^18.8.5",
    "@types/pluralize": "^0.0.29",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^7.6.0",
    "cypress": "^15.8.2",
    "eslint": "^9.38.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jotai-devtools": "^0.12.0",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "sass": "^1.86.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.46.2",
    "uuid": "^11.1.0",
    "vite": "^6.2.6",
    "vite-plugin-static-copy": "^2.3.2",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.1",
    "yaml-sort": "^2.1.0"
  },
  "lint-staged": {
    "public/i18n/*.yaml": "yaml-sort --lineWidth=-1 -i ",
    "*.{ts,tsx,js,jsx,json,html,css,scss,yaml,md}": "prettier --write"
  },
  "overrides": {
    "oidc-client-ts": {
      "crypto-js": "4.2.0"
    },
    "d3-color": "^3.1.0",
    "prismjs": "1.30.0",
    "qs": "^6.14.1"
  }
}
